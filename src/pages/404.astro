---
import Base from "../layouts/Base.astro";
---

<Base title="Tiritilli — 404" description="This page could not be found.">
  <main class="not-found">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>This is not the page<br />you're looking for.</h1>
      <hr class="rule accent" />
      <p>The link is broken, the page moved, or it never existed.</p>
      <a class="btn btn--primary" href="/">Back home</a>
    </div>
  </main>
</Base>

<style>
  .not-found {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--gutter);
    background: var(--paper);
  }

  .not-found .container {
    max-width: 40rem;
  }

  .not-found .btn {
    margin-top: 1.5rem;
  }
</style>
