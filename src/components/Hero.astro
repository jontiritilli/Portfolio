---
---

<section class="section hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow">Jonathan Tiritilli</p>
      <h1>Software engineer<br />and technical advisor.</h1>
      <hr class="rule accent" />
      <p>
        I build pragmatic web applications, untangle gnarly systems, and help
        small teams ship things that matter.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">Say hello</a>
        <a class="btn" href="#portfolio">See the work</a>
      </div>
    </div>
    <figure class="hero__portrait">
      <img src="/assets/images/me_img.jpg" alt="Portrait of Jonathan Tiritilli" />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(5rem, 14vh, 9rem);
  }

  .hero__inner {
    display: grid;
    gap: clamp(2.5rem, 6vw, 5rem);
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 820px) {
    .hero__inner {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .hero__copy h1 {
    margin-bottom: 1.25rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero__portrait {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    border: var(--hairline);
    max-width: 26rem;
    width: 100%;
    justify-self: center;
  }

  .hero__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
