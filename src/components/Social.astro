---
const links = [
  {
    label: "GitHub",
    href: "https://github.com/jontiritilli",
    icon: "github",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/jontiritilli",
    icon: "linkedin",
  },
  {
    label: "Twitter",
    href: "https://twitter.com/jontiritilli",
    icon: "twitter",
  },
];

const year = new Date().getFullYear();
---

<section class="section tight social">
  <div class="container social__inner">
    <div>
      <p class="eyebrow">Elsewhere</p>
      <h2>Find me online.</h2>
      <hr class="rule accent" />
    </div>
    <ul class="social__list">
      {
        links.map((link) => (
          <li>
            <a class="btn btn--icon" href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
              {link.icon === "github" && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.41c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.34-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.45.11-3.03 0 0 .98-.31 3.2 1.18a11.07 11.07 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.62 1.58.23 2.74.11 3.03.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5z" />
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5.001 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.94 1.83-1.93 3.77-1.93 4.03 0 4.78 2.57 4.78 5.91V21h-4v-5.55c0-1.32-.03-3.02-1.85-3.02-1.85 0-2.13 1.43-2.13 2.92V21H9z" />
                </svg>
              )}
              {link.icon === "twitter" && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2H21l-6.51 7.44L22 22h-6.83l-4.78-6.25L4.8 22H2l7.05-8.06L2 2h7l4.32 5.71L18.24 2zm-1.2 18h1.5L7.05 4H5.46l11.59 16z" />
                </svg>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <p class="social__footnote">© Jon Tiritilli — <span id="footer-year">{year}</span></p>
</section>

<style>
  .social {
    background: var(--paper-warm);
  }

  .social__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 720px) {
    .social__inner {
      grid-template-columns: 1fr auto;
    }
  }

  .social__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
  }

  .social__footnote {
    margin: 3rem auto 0;
    max-width: var(--content-width);
    padding-inline: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-mute);
  }
</style>
